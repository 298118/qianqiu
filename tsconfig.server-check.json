{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "server.js",
    "src/contracts/**/*.ts",
    "src/game/clientWorldState.js",
    "src/game/redactedState.js",
    "src/game/stateRules.js",
    "src/ai/index.js",
    "src/ai/modelRoutePolicy.js",
    "src/ai/providerSafety.js",
    "src/ai/providers/remoteHelpers.js",
    "src/routes/routeResponses.js",
    "src/storage/sessionRecord.js",
    "src/storage/sessionStore.js",
    "src/storage/jsonSessionAdapter.js",
    "src/storage/sqliteSessionAdapter.js",
    "src/storage/sqlitePromptRetrievalTables.js",
    "src/storage/sqliteSafeSearchTables.js",
    "src/storage/sqliteMaintenance.js"
  ]
}
