{
  "name": "qianqiu",
  "version": "0.1.0",
  "description": "Qianqiu / 千秋, a browser and Node.js historical simulation text game.",
  "main": "server.js",
  "scripts": {
    "prestart": "node scripts/ensureClientBuild.js",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:client": "vite --config vite.config.mjs",
    "build:client": "vite build --config vite.config.mjs",
    "typecheck:client": "tsc --project tsconfig.client.json --noEmit",
    "typecheck:server": "tsc --project tsconfig.server-check.json --noEmit",
    "build:server:probe": "tsc --project tsconfig.server-probe.json",
    "test:client": "vitest --config vitest.config.mjs run",
    "preview:client": "vite preview --config vite.config.mjs",
    "test": "node --test test/*.test.js",
    "check:docs-governance": "node scripts/checkGovernanceDocs.js",
    "qa:frontend-assets": "node scripts/frontendAssetQa.js --check",
    "qa:frontend-assets:write": "node scripts/frontendAssetQa.js --write --pixel",
    "qa:runtime-manifest": "node scripts/frontendRuntimeManifest.js",
    "qa:runtime-manifest:write": "node scripts/frontendRuntimeManifest.js --write",
    "qa:portrait-matrix": "node scripts/frontendPortraitMatrix.js",
    "qa:portrait-matrix:write": "node scripts/frontendPortraitMatrix.js --write",
    "qa:player-portraits": "node scripts/frontendPlayerPortraitAssets.js --check",
    "qa:player-portraits:write": "node scripts/frontendPlayerPortraitAssets.js --write",
    "qa:player-female-portraits": "node scripts/frontendPlayerFemalePortraitAssets.js --check",
    "qa:player-female-portraits:write": "node scripts/frontendPlayerFemalePortraitAssets.js --write",
    "qa:player-male-portraits": "node scripts/frontendPlayerMalePortraitAssets.js --check",
    "qa:player-male-portraits:write": "node scripts/frontendPlayerMalePortraitAssets.js --write",
    "qa:generic-npc-portraits": "node scripts/frontendGenericNpcPortraitAssets.js --check",
    "qa:generic-npc-portraits:write": "node scripts/frontendGenericNpcPortraitAssets.js --write",
    "qa:signature-npc-portraits": "node scripts/frontendSignatureNpcPortraitAssets.js --check",
    "qa:signature-npc-portraits:write": "node scripts/frontendSignatureNpcPortraitAssets.js --write",
    "qa:state-scene-portraits": "node scripts/frontendStateScenePortraitAssets.js --check",
    "qa:state-scene-portraits:write": "node scripts/frontendStateScenePortraitAssets.js --write",
    "qa:young-female-portraits": "node scripts/frontendYoungFemalePortraitAssets.js --check",
    "qa:young-female-portraits:write": "node scripts/frontendYoungFemalePortraitAssets.js --write",
    "qa:recovered-female-portraits": "node scripts/frontendRecoveredFemalePortraitAssets.js --check",
    "qa:recovered-female-portraits:write": "node scripts/frontendRecoveredFemalePortraitAssets.js --write",
    "qa:single-portrait-overrides": "node scripts/frontendSinglePortraitOverrides.js --check",
    "qa:single-portrait-overrides:write": "node scripts/frontendSinglePortraitOverrides.js --write",
    "qa:portrait-compression": "node scripts/frontendPortraitCompressionQa.js --check",
    "qa:portrait-compression:write": "node scripts/frontendPortraitCompressionQa.js --write",
    "eval:ai": "node scripts/aiEvaluationRunner.js && node --test test/aiEvalFixtures.test.js",
    "budget:client": "node scripts/clientBuildBudget.js",
    "smoke:browser": "npm run qa:runtime-manifest && npm run build:client && npm run budget:client && node scripts/clientSmoke.js",
    "smoke:browser:legacy": "node scripts/browserSmoke.js",
    "smoke:dual-mode": "node scripts/dualModeAcceptance.js",
    "smoke:provider": "node scripts/providerSmoke.js",
    "smoke:provider:tools": "node scripts/providerToolSmoke.js",
    "smoke:provider:ai-first": "node scripts/providerAiFirstSmoke.js",
    "smoke:provider:route": "node scripts/providerRouteHealth.js",
    "smoke:provider:long": "node scripts/providerLongRun.js",
    "smoke:exam-s69": "node scripts/mockImperialExamAcceptance.js",
    "storage:import:sqlite": "node scripts/importJsonSessionsToSqlite.js",
    "storage:geography:sqlite": "node scripts/sqliteGeographyTool.js",
    "storage:audit-events": "node scripts/auditEventArchiveTool.js",
    "storage:sqlite:status": "node scripts/sqliteMaintenanceTool.js status",
    "storage:sqlite:health": "node scripts/sqliteMaintenanceTool.js health",
    "storage:sqlite:backup": "node scripts/sqliteMaintenanceTool.js backup",
    "storage:sqlite:vacuum": "node scripts/sqliteMaintenanceTool.js vacuum",
    "storage:sqlite:export-safe": "node scripts/sqliteMaintenanceTool.js export-safe"
  },
  "keywords": [
    "historical-simulation",
    "text-game",
    "qianqiu"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@fontsource/long-cang": "^5.2.8",
    "@fontsource/ma-shan-zheng": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@fontsource/zcool-xiaowei": "^5.2.8",
    "ajv": "^8.20.0",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "lucide-react": "1.16.0",
    "openai": "^6.36.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "playwright-core": "^1.59.1",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
