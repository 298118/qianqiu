{
  "name": "qianqiu",
  "version": "0.1.0",
  "description": "Qianqiu / 千秋, a browser and Node.js historical simulation text game.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "check:docs-governance": "node scripts/checkGovernanceDocs.js",
    "eval:ai": "node scripts/aiEvaluationRunner.js && node --test test/aiEvalFixtures.test.js",
    "smoke:browser": "node scripts/browserSmoke.js",
    "smoke:dual-mode": "node scripts/dualModeAcceptance.js",
    "smoke:provider": "node scripts/providerSmoke.js",
    "smoke:provider:tools": "node scripts/providerToolSmoke.js",
    "smoke:provider:route": "node scripts/providerRouteHealth.js",
    "smoke:provider:long": "node scripts/providerLongRun.js",
    "smoke:exam-s69": "node scripts/mockImperialExamAcceptance.js",
    "storage:import:sqlite": "node scripts/importJsonSessionsToSqlite.js",
    "storage:geography:sqlite": "node scripts/sqliteGeographyTool.js",
    "storage:audit-events": "node scripts/auditEventArchiveTool.js"
  },
  "keywords": [
    "historical-simulation",
    "text-game",
    "qianqiu"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "ajv": "^8.20.0",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "openai": "^6.36.0"
  },
  "devDependencies": {
    "playwright-core": "^1.59.1"
  }
}
